#!/usr/bin/env bash
# the shebang is ignored, but nice for editors

if ! has nix_direnv_version || ! nix_direnv_version 3.1.0; then
  echo 'While direnv evaluated .envrc, could not find nix-direnv or version is too old [https://github.com/nix-community/nix-direnv]' >&2
  echo 'Will use regular flake mode instead' >&2
fi

use flake
